# Copie para ".env" na raiz do projeto (o ".env" não vai pro Git).

# --- Opção A: Postgres local ou Docker ---
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nexus?schema=public"

# --- Opção B: Supabase (substitua [SENHA] pela senha do projeto) ---
#
# O painel costuma mostrar algo como:
#   postgresql://postgres:[SENHA]@db.SEU_REF.supabase.co:5432/postgres
#
# Use essa URL na DATABASE_URL quando a sua rede conseguir falar com o host
# db.* na porta 5432 (é a conexão "direta" ao Postgres).
#
# Aviso "Not IPv4 compatible" / "use Session Pooler if on IPv4":
# em algumas redes só IPv4 o host db.* pode não responder; aí o Supabase
# indica outra URL (Session Pooler, outra porta, às vezes parâmetros extras).
# Nesse caso, leia a doc atual "Connect to Postgres" + "Prisma" no site do
# Supabase: para Prisma com pooler costuma existir também uma "direct URL"
# para migrations — só adicione isso no schema quando for o seu caso.
#
# Nunca commite senha nem arquivo .env.

DATABASE_URL="postgresql://postgres:[SENHA]@db.SEU_REF.supabase.co:5432/postgres"

# --- API Nest (JWT) — obrigatório para subir a API ---
# Gere um segredo forte (ex.: 32+ caracteres aleatórios).
JWT_SECRET="altere-para-um-segredo-longo-e-aleatorio"
# Opcional; padrão na API se omitido: 7d
# JWT_EXPIRES_IN="7d"

# --- Supabase Storage (retrato do aluno — `POST /api/v1/students/:id/portrait`) ---
# URL do projeto (Settings → API → Project URL).
SUPABASE_URL="https://SEU_REF.supabase.co"
# Service role (Settings → API) — só no servidor Nest; nunca no Next público.
SUPABASE_SERVICE_ROLE_KEY="cole-a-service-role-key"
# Bucket já criado no painel (padrão no código: student-portraits).
# SUPABASE_STORAGE_BUCKET="student-portraits"
# TTL da URL assinada em segundos (60 a 86400; padrão 3600).
# PORTRAIT_SIGNED_URL_TTL_SECONDS="3600"

# --- Primeiro usuário da secretaria (sem seed no repo) ---
# Depois das migrations, crie manualmente um registro em `User`
# (email único + passwordHash em bcrypt, 10 rounds — o mesmo formato que
# o login da API valida com bcrypt.compare). Ex.: script pontual, SQL com
# hash gerado fora do banco, ou fluxo admin quando existir.
